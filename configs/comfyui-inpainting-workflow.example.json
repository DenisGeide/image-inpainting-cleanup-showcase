{
  "note": "Public descriptor for a ComfyUI SDXL inpainting cleanup workflow.",
  "runtime": "ComfyUI",
  "task": "image inpainting / masked background reconstruction",
  "public_scope": "owned or authorized images",
  "nodes": {
    "load_checkpoint": {
      "type": "Load Checkpoint",
      "checkpoint": "sdxl-inpainting-checkpoint.safetensors",
      "outputs": ["MODEL", "CLIP", "VAE"]
    },
    "load_image": {
      "type": "Load Image",
      "input": "source image with mask"
    },
    "positive_prompt": {
      "type": "CLIP Text Encode",
      "text": "clean background, high quality, seamless"
    },
    "negative_prompt": {
      "type": "CLIP Text Encode",
      "text": "watermark, text, logo, signature, bad quality"
    },
    "vae_encode_for_inpainting": {
      "type": "VAE Encode (for Inpainting)",
      "grow_mask_by": 6
    },
    "ksampler": {
      "type": "KSampler",
      "steps": 20,
      "cfg": 8.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "vae_decode": {
      "type": "VAE Decode"
    },
    "save_image": {
      "type": "Save Image",
      "filename_prefix": "ComfyUI"
    }
  }
}
